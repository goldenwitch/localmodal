# Downloaded paper PDFs are reproducible via fetch_papers.py; don't commit them.
pdf/

# The pinned Modal docs mirror is reproducible via fetch_modal_docs.py.
modal-docs/

# The pinned VS Code docs mirror is reproducible via fetch_vscode_docs.py.
vscode-docs/

# Semantic search index is rebuildable from the sources via search.py.
.index/

# Source-management artifacts are generation-qualified local materializations.
# .scout-ledger.json is source-control runtime state; sources.json remains the
# tracked pre-activation freshness ledger.
scout-source--*/
.scout-index/
.scout-index-stage/
.scout-publications/
.scout-publications-stage/
.scout-attempts/
.scout-staging/
.scout-transition.lock
.scout-ledger.json
.scout-ledger.json.journal
.scout-ledger.json.lock
.scout-ledger.json.recovery.lock
